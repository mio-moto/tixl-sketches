    {
      "Id": "26c41e8a-0a41-4f2c-b3aa-985a9e114964"/*Prime*/,
      "SymbolId": "5880cbc3-a541-4484-a06a-0e6f77cdbe8e",
      "Name": "Prime",
      "InputValues": [
        {
          "Id": "ceeae47b-d792-471d-a825-49e22749b7b9"/*InputString*/,
          "Type": "System.String",
          "Value": "float3 HullFunction(float u, float v) {\n  return float3(\n    (v + 1) * 10,\n    (u - 0.5) + sin(u) ,\n    v + u + sin(u + v)\n  );\n}"
        }
      ],
      "Outputs": []
    },
    {
      "Id": "28558d0c-4748-47d0-9cba-6607e891982e"/*String*/,
