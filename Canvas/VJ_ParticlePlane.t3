      "InputValues": [
        {
          "Id": "ceeae47b-d792-471d-a825-49e22749b7b9"/*InputString*/,
          "Type": "System.String",
          "Value": "float3 HullFunction(float u, float v) {\n  return float3(\n    (u * cos(v)) / tan(u),\n    u * sin(u) * sin(v) * tan(u),\n    -u  * tan(u / v)\n  );\n}"
        }
      ],
      "Outputs": []
    },
    {
      "Id": "2d38f258-a46f-4cca-aac4-54fe1e0d9375"/*Prime*/,
