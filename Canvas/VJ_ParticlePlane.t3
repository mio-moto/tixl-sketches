    {
      "Id": "16854d0e-c198-45d8-b3b5-676654405e01"/*Prime*/,
      "SymbolId": "5880cbc3-a541-4484-a06a-0e6f77cdbe8e",
      "Name": "Prime",
      "InputValues": [
        {
          "Id": "ceeae47b-d792-471d-a825-49e22749b7b9"/*InputString*/,
          "Type": "System.String",
          "Value": "float3 HullFunction(float u, float v) {\n  return float3(\n    u * cos(v) * sin(u),\n    u * sin(u) * sin(u / v),\n    -u + tan(v)\n  );\n}"
        }
      ],
      "Outputs": []
    },
    {
      "Id": "1ac0d443-f585-49b2-aa3c-d64a85b6ee3f"/*String*/,
      "SymbolId": "5880cbc3-a541-4484-a06a-0e6f77cdbe8e",
      "InputValues": [
        {
          "Id": "ceeae47b-d792-471d-a825-49e22749b7b9"/*InputString*/,
          "Type": "System.String",
          "Value": "float3 HullFunction(float u, float v) {\n  return float3(\n    (u * cos(v) * sin(u)) * tan(u / v),\n    u * sin(u) * sin(v) * tan(u),\n    -u * sin(v) + tan(u / v)\n  );\n}"
        }
      ],
      "Outputs": []
    },
    {
      "Id": "1bd726e9-148c-42f2-ac10-123ecf834f30"/*String*/,
      "SymbolId": "5880cbc3-a541-4484-a06a-0e6f77cdbe8e",
      "InputValues": [
        {
          "Id": "ceeae47b-d792-471d-a825-49e22749b7b9"/*InputString*/,
          "Type": "System.String",
          "Value": "#define Sampling Center.xy\n#define SampleOffset float2(A, B)\n#define NoiseImpact float2(C, D)\n\nint gs = sqrt(TotalCount);\nfloat2 gpos = float2(i%gs,i/gs)/gs-0.5;\nfloat u = gpos.x * (2.0 * PI);\nfloat v = (gpos.y - 0.5) * (PI);\nu *= Sampling.x;\nv *= Sampling.y;\nu += SampleOffset.x;\nv += SampleOffset.y;\n\nfloat2 noiseOffset = Image[gpos.xy * float2(1024, 1024) + float2(512, 512)].xy * NoiseImpact;\nu *= 1.0 + noiseOffset.x;\nv *= 1.0 + noiseOffset.y;\n\np.Position = HullFunction(u, v);"
        }
      ],
      "Outputs": []
    },
    {
      "Id": "1c1628cc-0f68-496a-8e6f-6144fd992f23"/*Prime*/,
      "SymbolId": "5880cbc3-a541-4484-a06a-0e6f77cdbe8e",
      "Name": "Prime",
      "InputValues": [
        {
          "Id": "ceeae47b-d792-471d-a825-49e22749b7b9"/*InputString*/,
          "Type": "System.String",
          "Value": "float3 HullFunction(float u, float v) {\n  return float3(\n    v * cos(v) * cos(u * v),\n    u * sin(u / v) + sin(v),\n    -u * sin(v)\n  );\n}"
        }
      ],
      "Outputs": []
    },
    {
      "Id": "1e28244a-099c-46a2-a34b-8fbc4ba432da"/*String*/,
      "SymbolId": "5880cbc3-a541-4484-a06a-0e6f77cdbe8e",
      "InputValues": [
        {
          "Id": "ceeae47b-d792-471d-a825-49e22749b7b9"/*InputString*/,
          "Type": "System.String",
          "Value": "float3 HullFunction(float u, float v) {\n  return float3(\n    (u / cos(v * A)) * sin(u) + A,\n    u * tan(u) * cos(v),\n    -u + sin(u * v)\n  );\n}"
        }
      ],
      "Outputs": []
    },
    {
      "Id": "1edead42-3733-4c23-b25c-c054899ea68a"/*String*/,
      "SymbolId": "5880cbc3-a541-4484-a06a-0e6f77cdbe8e",
      "InputValues": [
        {
          "Id": "ceeae47b-d792-471d-a825-49e22749b7b9"/*InputString*/,
          "Type": "System.String",
          "Value": "float3 HullFunction(float u, float v) {\n  return float3(\n    (u * cos(v) * sin(u)) * tan(u / v) + u,\n    u * sin(u) * sin(v) * tan(u),\n    -u  + tan(u / v)\n  );\n}"
        }
      ],
      "Outputs": []
    },
    {
