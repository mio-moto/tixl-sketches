    {
      "Id": "e3e672ad-f0c4-450c-b5ce-e1b217051402"/*Prime*/,
      "SymbolId": "5880cbc3-a541-4484-a06a-0e6f77cdbe8e",
      "Name": "Prime",
      "InputValues": [
        {
          "Id": "ceeae47b-d792-471d-a825-49e22749b7b9"/*InputString*/,
          "Type": "System.String",
          "Value": "float3 HullFunction(float u, float v) {\n  return float3(\n    u * cos(v /A) * sin(u),\n    u * sin(u) * sin(v),\n    -u * sin(v)\n  );\n}"
        }
      ],
      "Outputs": []
    },
    {
      "Id": "f07637bb-9db3-4925-b14c-a709121dc462"/*Prime*/,
      "SymbolId": "5880cbc3-a541-4484-a06a-0e6f77cdbe8e",
      "Name": "Prime",
      "InputValues": [
        {
          "Id": "ceeae47b-d792-471d-a825-49e22749b7b9"/*InputString*/,
          "Type": "System.String",
          "Value": "float3 HullFunction(float u, float v) {\n  return float3(\n    v / cos(u * v),\n    (v/A) + tan(v),\n    -u * sin(v)\n  );\n}"
        }
      ],
      "Outputs": []
    },
