          "Id": "e5a7649f-684e-4938-8ae3-7289f5b9ff45"/*B*/,
          "Type": "System.Single",
          "Value": 0.0
        },
        {
          "Id": "e9712b03-e7aa-4fe5-b5cf-f2c5d0c0b0df"/*ShaderCode*/,
          "Type": "System.String",
          "Value": "float2 u=p.Position.xy;\nint zi=int(round(abs(p.Position.z)));\nint iter=int(A);\n\n\niter=clamp(iter,0,1024);\nfloat2 tp=u;\n\nfloat2 z=u;\nbool escape=0;\nfor(int i=0;i<iter;i++){\n    z=cmul(z,z)+u;\n    if(i==zi)tp=z;\n}\n\nif(any(isnan(z))){\n    escape=1;\n}else if(any(!isfinite(z))){\n    escape=1;\n}else if(length(z)>2){\n    escape=1;\n}\n\n//if(!escape){p.Color=0;}\np.Color.w*=lerp(C,D,float(escape));\np.Position.xyz=float3(tp.xy,0);\n"
        }
      ],
      "Outputs": []
    },
