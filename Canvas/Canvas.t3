        {
          "Id": "ceeae47b-d792-471d-a825-49e22749b7b9"/*InputString*/,
          "Type": "System.String",
          "Value": "float3 HullFunction(float u, float v)\n{\n    return float3(\n        u * cos(cos(u)) * pow(cos(v), 1),\n        0.28 * v * cos(cos(u)) * sin(v),\n        -u * sin(cos(u))\n    );\n}"
        }
      ],
      "Outputs": []
    },
