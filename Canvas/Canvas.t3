    {
      "Id": "95d369dd-d76a-4e63-839f-023801aa56ef"/*random disk*/,
      "SymbolId": "3d958f08-9c0f-45eb-a252-de880b5834f3",
      "Name": "random disk",
      "InputValues": [
        {
          "Id": "20226539-a481-4df6-8dc7-cc65de915ea9"/*D*/,
          "Type": "System.Single",
          "Value": 16.6
        },
        {
          "Id": "2a0cf45c-bcf5-4802-b32b-84cef0f1c129"/*Count*/,
          "Type": "System.Int32",
          "Value": 4414
        },
        {
          "Id": "362e446c-b471-40fc-a21f-ddc25dafd01b"/*GainAndBias*/,
          "Type": "System.Numerics.Vector2",
          "Value": {
            "X": 0.5,
            "Y": 0.21
          }
        },
        {
          "Id": "864dfe5a-14f2-490f-be9c-ee13ad58605c"/*AdditionalDefines*/,
          "Type": "System.String",
          "Value": "float4 rndz(int3 p, int s) {int4 c=int4(p.xyz,s);int r=(int(0x3504f333*c.x*c.x+c.y)*int(0xf1bbcdcb*c.y*c.y+c.x)*int(0xbf5c3da7*c.z*c.z+c.y)*int(0x2eb164b3*c.w*c.w+c.z));\nint4 r4=int4(0xbf5c3da7,0xa4f8e125,0x9284afeb,0xe4f5ae21)*r;return (float4(r4)*(2.0/8589934592.0)+0.5)*0.99999;}\nfloat2 r2d(float2 x,float a){a*=acos(-1)*2;return float2(cos(a)*x.x+sin(a)*x.y,cos(a)*x.y-sin(a)*x.x);}"
        },
        {
          "Id": "e9712b03-e7aa-4fe5-b5cf-f2c5d0c0b0df"/*ShaderCode*/,
          "Type": "System.String",
          "Value": "int seed=int(C);\nint seed2=int(D);\nfloat4 rnd1=rndz(int3(idx+1,1,seed2),seed);\nfloat2 uv=rnd1.xy;\n\nfloat g=uv.x;\n//g=lerp(A,B,g);\nfloat r=uv.y;\nr=ApplyGainAndBias(r, GainAndBias);\n//r=lerp(C,D,r);\nr=pow(r,.5);\n\nfloat2 pos=r2d(float2(0,r*2),g);\np.Position=float3(pos.xy,0);\n"
        }
      ],
      "Outputs": []
    },
