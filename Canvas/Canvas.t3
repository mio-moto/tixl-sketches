    },
    {
      "Id": "ce64db5f-1f11-4320-b4b9-620eeb4fb17a"/*CustomSDF*/,
      "SymbolId": "637d00e4-ab63-4fe3-8e63-1e206c728841",
      "InputValues": [
        {
          "Id": "3c366d34-c398-410e-972b-d8cc2baffddb"/*A*/,
          "Type": "System.Single",
          "Value": 0.0
        },
        {
          "Id": "48a0699d-1207-4e18-ab9b-4da7f77cc7aa"/*AdditionalDefines*/,
          "Type": "System.String",
          "Value": "void pR(inout float2 p, float a) {\np = cos(a)*p + sin(a)*float2(p.y, -p.x);\n}\nfloat length6( float3 p )\n{\np = p*p*p; p = p*p;\nreturn pow( p.x + p.y + p.z, 1.0/6.0 );\n}\n"
        },
        {
          "Id": "bde89b93-224c-4a3f-85ab-d85b0401c02a"/*DistanceFunction*/,
          "Type": "System.String",
          "Value": "    const int iterations = 20;\n\n    float d = A*5. - p.z;\n   p=p.yxz;\n    pR(p.yz, 1.570795);\n    p.x += 6.5;\n\n    p.yz = mod(abs(p.yz)-.0, 20.) - 10.;\n    float scale = 1.25;\n    \n    p.xy /= (1.+d*d*0.0005);\n    \nfloat l = 0.;\n\n    for (int i=0; i<iterations; i++) {\np.xy = abs(p.xy);\np = p*scale + float3(-3. + d*0.0095,-1.5,-.5);\n        \npR(p.xy,0.35-d*0.015);\npR(p.yz,0.5+d*0.02);\n\n        l =length6(p);\n}\nreturn l*pow(scale, -float(iterations))-.15;\n"
        }
      ],
      "Outputs": []
    },
    {
      "Id": "ceada226-f3c3-4d0e-a918-841c914e869e"/*Vector2Components*/,
      "SymbolId": "0946c48b-85d8-4072-8f21-11d17cc6f6cf",
      "InputValues": [
        {
          "Id": "36f14238-5bb8-4521-9533-f4d1e8fb802b"/*Value*/,
