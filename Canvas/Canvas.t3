    {
      "Id": "0e2f580a-f627-4d51-a97f-93066da8f0e8"/*mandelbrot_simple*/,
      "SymbolId": "46daab0e-e957-413e-826c-0699569d0e07",
      "Name": "mandelbrot_simple",
      "InputValues": [
        {
          "Id": "83e06d04-02bd-40cc-8666-d5dd62a9e63e"/*Resolution*/,
          "Type": "T3.Core.DataTypes.Vector.Int2",
          "Value": {
            "X": 512,
            "Y": 512
          }
        },
        {
          "Id": "8c3ffefe-8721-4dde-b252-22eb8be02d3f"/*ShaderCode*/,
          "Type": "System.String",
          "Value": "float2 asp=float2(float(TargetWidth)/float(TargetHeight),1);\nfloat2 u=float2(uv.x*2-1,1-2*uv.y)*2*asp;\nfloat2 z=u;\nbool hit=1;\nfor(int i=0;i<64;i++){\nz=cmul(z,z)+u;\nif(length(z)>2){hit=0;break;}\n}\nc.rgb=float(hit);\nc.rgb=SampleGradient(float(hit));"
        },
        {
          "Id": "c9a801ec-13fb-4ad4-b0cd-d125b5db500a"/*AdditionalCode*/,
          "Type": "System.String",
          "Value": "\nfloat2 cmul(float2 a,float2 b){return float2(a.x*b.x-a.y*b.y,a.y*b.x+a.x*b.y);}"
        },
        {
          "Id": "e1c50230-8821-4109-8119-fd8b66b43e7f"/*Gradient*/,
          "Type": "T3.Core.DataTypes.Gradient",
          "Value": {
            "Gradient": {
              "Interpolation": "Linear",
              "Steps": [
