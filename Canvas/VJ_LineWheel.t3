          "Type": "System.String",
          "Value": "float3 HullFunction(float u, float v) {\n  return float3(\n    (u * cos(v)) / tan(u),\n    u * sin(u) * sin(v) * tan(u),\n    -u  * tan(u / v)\n  );\n}"
        }
