        {
          "Id": "ceeae47b-d792-471d-a825-49e22749b7b9"/*InputString*/,
          "Type": "System.String",
          "Value": "float3 HullFunction(float u, float v) {\n  return float3(\n    u * cos(v) * sin(u) * 5,\n    u * sin(u) * sin(v) * 5,\n    -u + sin(v) * 10\n  );\n}"
